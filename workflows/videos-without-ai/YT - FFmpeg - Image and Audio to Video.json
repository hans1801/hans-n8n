      "id": "ded770aa-47e9-49a6-9223-3f3040a5a072",
      "name": "Save Audio Locally"
    },
    {
      "parameters": {
        "command": "=cd {{ $('Config').item.json.path }} &&\n\nIMAGE=\"{{ $('Download Image').item.binary.data.fileName }}\"\nAUDIO=\"{{ $('Download Audio').item.binary.data.fileName }}\"\nOUTPUT=\"{{ $('Config').item.json.filename_prefix }}${IMAGE}.{{ $('Config').item.json.video_extension }}\"\n\nZI={{ $('Config').item.json.zoom_in }}\nZO={{ $('Config').item.json.zoom_out }}\nZOOM={{ $('Config').item.json.zoom_amount }}\nFPS={{ $('Config').item.json.fps }}\nROT={{ $('Config').item.json.rotation_deg }}\nROT_SPEED={{ $('Config').item.json.rotation_speed }}\n\nSIZE=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 \"$IMAGE\")\n\nDUR=$(ffprobe -v error -show_entries format=duration -of csv=p=0 \"$AUDIO\")\n\nTOTAL_FRAMES=$(printf \"%.0f\" $(echo \"$DUR*$FPS\" | bc))\nF_IN=$(printf \"%.0f\" $(echo \"$TOTAL_FRAMES*$ZI\" | bc))\nF_OUT=$(printf \"%.0f\" $(echo \"$TOTAL_FRAMES*(1-$ZO)\" | bc))\n\nffmpeg -y -loop 1 \\\n-i \"$IMAGE\" \\\n-i \"$AUDIO\" \\\n-vf \"zoompan=z='if(lt(on,$F_IN),1+$ZOOM*(on/$F_IN),if(lt(on,$F_OUT),1+$ZOOM,(1+$ZOOM)-$ZOOM*((on-$F_OUT)/($TOTAL_FRAMES-$F_OUT))))':d=1:fps=$FPS:s=$SIZE:x='iw/2-(iw/zoom/2)':y='ih/2-(ih/zoom/2)',rotate='$ROT*PI/180*sin(2*PI*t/$ROT_SPEED)':fillcolor=black,format=yuv420p\" \\\n-shortest \\\n-c:v libx264 -c:a aac -pix_fmt yuv420p \\\n\"$OUTPUT\""
      },
