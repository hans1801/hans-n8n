    {
      "parameters": {
        "executeOnce": false,
        "command": "=cd {{ $('Config').item.json.path }} &&\n\nffmpeg -y -i video.{{ $('Config').item.json.video_extension }} \\\n  -map 0:v -c:v copy video_copy.{{ $('Config').item.json.video_extension }} \\\n  -map 0:a -c:a libmp3lame -b:a 192k audio.mp3\n"
