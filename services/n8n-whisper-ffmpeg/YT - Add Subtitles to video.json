    {
      "parameters": {
        "command": "=cd {{ $('Config').item.json.path }} &&\n\nffmpeg -i video.{{ $('Config').item.json.video_extension }} -vf \"subtitles=subtitles.srt:force_style='FontName=Impact,FontSize=24,PrimaryColour=&H00FFFF,OutlineColour=&H000000,BorderStyle=1,Outline=2,Alignment=2,MarginV=50'\" -c:a copy subtitled_video.{{ $('Config').item.json.video_extension }} -y"
      },
      "type": "n8n-nodes-base.executeCommand",
